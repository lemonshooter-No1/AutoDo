# 复制为 .env 后填写（不要提交 .env）
PORT=8000
# OPENAI_API_KEY=sk-...   # 未来接真 AI 时使用
# DeepSeek / Silicon Flow 配置（可选）
# 如果有真实 API Key，请在 .env 中设置：
# SILICON_FLOW_API_KEY=sk-... 
# SILICON_FLOW_API_BASE=https://api.siliconflow.cn/v1
#
# 本地开发可开启 mock 模式（不需要真实 key）：
# USE_MOCK_DEEPSEEK=1  # 设置为 1 或 true 时，后端会返回可预测的模拟模型输出，便于离线测试
